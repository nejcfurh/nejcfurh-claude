{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(awk *)",
      "Bash(cat:*)",
      "Bash(find:*)",
      "Bash(gh api:*)",
      "Bash(gh auth:*)",
      "Bash(gh pr:*)",
      "Bash(git *)",
      "Bash(grep:*)",
      "Bash(ls:*)",
      "Bash(node *)",
      "Bash(npm install:*)",
      "Bash(npm run *)",
      "Bash(npm uninstall:*)",
      "Bash(npx eslint:*)",
      "Bash(npx tsc:*)",
      "Bash(pnpm run *)",
      "Bash(yarn run *)",
      "Bash(bun run *)",
      "Bash(rm:*)",
      "Bash(wc:*)",
      "Read(//tmp/**)",
      "Read(**/.env.example)",
      "Read(**/.env.sample)",
      "Edit(**/.env.example)",
      "Edit(**/.env.sample)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:docs.github.com)",
      "mcp__context7__resolve-library-id",
      "mcp__context7__query-docs",
      "mcp__dash-api__list_installed_docsets",
      "mcp__dash-api__search_documentation",
      "mcp__plugin_figma_figma__get_design_context",
      "mcp__plugin_figma_figma__get_metadata",
      "mcp__plugin_figma_figma__get_screenshot"
    ],
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.local)",
      "Read(**/.env.*.local)",
      "Read(**/.env.development)",
      "Read(**/.env.production)",
      "Read(**/.env.staging)",
      "Read(**/.env.test)",
      "Read(**/.env.dev)",
      "Read(**/.env.prod)",
      "Read(~/.ssh/**)",
      "Read(~/.gnupg/**)",
      "Read(~/.aws/**)",
      "Read(~/.config/gcloud/**)",
      "Read(~/.config/gh/hosts.yml)",
      "Read(~/.kube/**)",
      "Read(~/.docker/config.json)",
      "Read(~/.npmrc)",
      "Read(~/.netrc)",
      "Read(~/.pypirc)",
      "Read(~/.vault-token)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*.p12)",
      "Read(**/*.pfx)",
      "Read(**/*.jks)",
      "Read(**/*-key.json)",
      "Read(**/service-account*.json)",
      "Read(**/credentials.json)",
      "Read(**/.vault-token)",
      "Read(**/.htpasswd)",
      "Read(~/.git-credentials)",
      "Read(~/.zsh_history)",
      "Read(~/.bash_history)",
      "Read(**/*.kubeconfig)",
      "Read(~/.azure/**)",
      "Edit(**/.env)",
      "Edit(**/.env.local)",
      "Edit(**/.env.*.local)",
      "Edit(**/.env.development)",
      "Edit(**/.env.production)",
      "Edit(**/.env.staging)",
      "Edit(**/.env.test)",
      "Edit(**/.env.dev)",
      "Edit(**/.env.prod)",
      "Edit(~/.ssh/**)",
      "Edit(~/.gnupg/**)",
      "Edit(~/.aws/**)",
      "Edit(~/.npmrc)",
      "Edit(~/.netrc)",
      "Edit(~/.docker/config.json)",
      "Edit(~/.kube/**)",
      "Edit(~/.config/gcloud/**)",
      "Edit(~/.azure/**)",
      "Edit(**/*.pem)",
      "Edit(**/*.key)",
      "Edit(**/*-key.json)",
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(dd *)",
      "Bash(mkfs *)",
      "Bash(shred *)",
      "Bash(chmod * ~/.ssh/*)",
      "Bash(chmod * ~/.gnupg/*)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(gh repo delete *)",
      "Bash(git push origin main *)",
      "Bash(git push * main)",
      "Bash(gh pr merge *)",
      "Edit(**/package-lock.json)",
      "Edit(**/yarn.lock)",
      "Edit(**/pnpm-lock.yaml)",
      "Edit(**/bun.lock)",
      "Bash(*DROP TABLE*)",
      "Bash(*DROP DATABASE*)",
      "Bash(*TRUNCATE TABLE*)",
      "Bash(*drop table*)",
      "Bash(*drop database*)",
      "Bash(*truncate table*)"
    ],
    "ask": [
      "Bash(git clean -fd *)",
      "Bash(git clean -f *)",
      "Bash(npm publish*)",
      "Bash(rm -r *)",
      "Bash(rm -fr *)"
    ],
    "defaultMode": "auto"
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true
  },
  "model": "claude-fable-5[1m]",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "HOOK=\"$HOME/.claude/hooks/git-gate-dispatch.sh\"; [ -x \"$HOOK\" ] && exec \"$HOOK\"",
            "if": "Bash(git *)",
            "timeout": 480
          },
          {
            "type": "command",
            "command": "HOOK=\"$HOME/.claude/hooks/pre-git-state-refresh.sh\"; [ -x \"$HOOK\" ] && exec \"$HOOK\"",
            "if": "Bash(gh pr *)",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "HOOK=\"$HOME/.claude/hooks/pre-pr-test-gate.sh\"; [ -x \"$HOOK\" ] && exec \"$HOOK\"",
            "if": "Bash(gh pr create *)",
            "timeout": 120
          },
          {
            "type": "command",
            "command": "HOOK=\"$HOME/.claude/hooks/pre-merge-gate.sh\"; [ -x \"$HOOK\" ] && exec \"$HOOK\"",
            "if": "Bash(gh *)",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "HOOK=\"$HOME/.claude/hooks/auto-format.sh\"; [ -x \"$HOOK\" ] && \"$HOOK\" || true",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "HOOK=\"$HOME/.claude/hooks/post-edit-typecheck.sh\"; if [ -x \"$HOOK\" ]; then \"$HOOK\"; fi",
            "timeout": 60
          },
          {
            "type": "command",
            "command": "HOOK=\"$HOME/.claude/hooks/invalidate-verify-marker.sh\"; [ -x \"$HOOK\" ] && \"$HOOK\" || true",
            "timeout": 5
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt|idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.claude/scripts/notify.sh\" \"Claude Code needs your attention\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "\"$HOME/.claude/scripts/chime.sh\" 1.5",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.claude/scripts/chime.sh\" 2",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "HOOK=\"$HOME/.claude/hooks/retro-nudge.sh\"; [ -x \"$HOOK\" ] && \"$HOOK\" || true",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Reminder: follow the global workflow. Minimal fix first for bugs. One question per turn. Run /verify-done before pushing. Never add AI attribution to commits.'"
          }
        ]
      },
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "HOOK=\"$HOME/.claude/hooks/symlink-check.sh\"; [ -x \"$HOOK\" ] && \"$HOOK\" || true",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "HOOK=\"$HOME/.claude/hooks/auto-sync-config.sh\"; [ -x \"$HOOK\" ] && \"$HOOK\" || true",
            "timeout": 20
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/scripts/statusline.sh"
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "figma@claude-plugins-official": true,
    "refactoring-ui-skills@refactoring-ui-plugin": true
  },
  "extraKnownMarketplaces": {
    "refactoring-ui-plugin": {
      "source": {
        "source": "github",
        "repo": "gnurio/refactoring-ui-plugin"
      }
    }
  },
  "tui": "default",
  "skipWorkflowUsageWarning": true,
  "editorMode": "normal",
  "autoCompactEnabled": true
}
